<version xsi:noNamespaceSchemaLocation="classpath:com/runwaysdk/resources/xsd/version.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <doIt>
    <create>
  <mdVertex
    name="gov.geoplatform.uasdm.graph.ImageSet"
    label="Document"
    generateController="false">
    <attributes>
      <char
        name="name"
        label="Name"
        size="256"
        required="true" />
      <dateTime
        name="lastUpdateDate"
        label="Last Update Date"
        required="true" />
      <boolean
        name="published"
        label="Published"
        required="false" />
      <boolean
        name="locked"
        label="Locked"
        required="false" />
      <reference
        name="lockedBy"
        label="Locked By"
        required="false"
        type="com.runwaysdk.system.SingleActor" />
      <text
        name="boundingBox"
        label="boundingBox"
        required="false" />
    </attributes>
  </mdVertex>

  <mdEdge
    name="gov.geoplatform.uasdm.graph.ComponentHasImageSet"
    label="Component Has Raw Set"
    parent="gov.geoplatform.uasdm.graph.UasComponent"
    child="gov.geoplatform.uasdm.graph.ImageSet">
  </mdEdge>

  <mdEdge
    name="gov.geoplatform.uasdm.graph.ImageSetHasDocument"
    label="Product Has Raw Set"
    child="gov.geoplatform.uasdm.graph.Document"
    parent="gov.geoplatform.uasdm.graph.ImageSet">
  </mdEdge>            
    
    </create>
    <update>
      <mdVertex name="gov.geoplatform.uasdm.graph.Document">
        <create>
          <attributes>
            <point name="point" label="Point" srid="4326" required="false" />
          </attributes>
        </create>
      </mdVertex>    
    
    </update>
    
    <permissions>
      <role roleName="geoprism.admin.Administrator">
        <grant>
          <mdBusinessPermission type="gov.geoplatform.uasdm.graph.ImageSet">
            <operation name="ALL" />
          </mdBusinessPermission>
          <mdRelationshipPermission type="gov.geoplatform.uasdm.graph.ComponentHasImageSet">
            <operation name="ALL" />
          </mdRelationshipPermission>
          <mdRelationshipPermission type="gov.geoplatform.uasdm.graph.ImageSetHasDocument">
            <operation name="ALL" />
          </mdRelationshipPermission>
        </grant>
      </role>
      <role roleName="geoprism.admin.DashboardBuilder">
        <grant>
          <mdBusinessPermission type="gov.geoplatform.uasdm.graph.ImageSet">
            <operation name="ALL" />
          </mdBusinessPermission>
          <mdRelationshipPermission type="gov.geoplatform.uasdm.graph.ComponentHasImageSet">
            <operation name="ALL" />
          </mdRelationshipPermission>
          <mdRelationshipPermission type="gov.geoplatform.uasdm.graph.ImageSetHasDocument">
            <operation name="ALL" />
          </mdRelationshipPermission>
        </grant>
      </role>
    </permissions>          
  </doIt>
  <undoIt>
    <delete>
      <object key="gov.geoplatform.uasdm.graph.Document.point" type="com.runwaysdk.system.metadata.MdAttribute" />
      <object key="gov.geoplatform.uasdm.graph.ImageSetHasDocument" type="com.runwaysdk.system.metadata.MdEdge" />
      <object key="gov.geoplatform.uasdm.graph.ComponentHasImageSet" type="com.runwaysdk.system.metadata.MdEdge" />
      <object key="gov.geoplatform.uasdm.graph.ImageSet" type="com.runwaysdk.system.metadata.MdVertex" />   
    </delete>
  </undoIt>
</version>